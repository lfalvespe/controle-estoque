<h1 class="page-title">Produtos</h1>

{{#if deleted}}
<div class="alert alert-success" id="successAlert">
    ✅ Produto excluído com sucesso!
</div>
{{/if}}

<div class="search-container">
    <form action="/products" method="GET" class="search-form">
        <input 
            type="text" 
            name="q" 
            class="search-input" 
            placeholder="Buscar por nome ou descrição..." 
            value="{{searchQuery}}"
        >
        <select name="category" id="filter-category" class="search-input">
            <option value="">Todas as categorias</option>
            {{#each categories}}
                <option value="{{this}}" {{#if (eq this ../selectedCategory)}}selected{{/if}}>{{this}}</option>
            {{/each}}
        </select>
        <select name="subcategory" id="filter-subcategory" class="search-input">
            <option value="">Todas as subcategorias</option>
        </select>
        <button type="submit" class="search-btn">🔍 Buscar</button>
        {{#if products}}
            <div class="products-view-controls" aria-label="Modo de visualizacao dos produtos">
                <button type="button" class="view-toggle-btn is-active" data-view="grid">Grade</button>
                <button type="button" class="view-toggle-btn" data-view="list">Lista</button>
            </div>
        {{/if}}
        {{#if hasFilters}}
            <a href="/products" class="search-clear">Limpar</a>
        {{/if}}
    </form>
    {{#if hasFilters}}
        <p class="search-info">
            Filtros:
            {{#if searchQuery}}<strong>texto:</strong> {{searchQuery}}{{/if}}
            {{#if selectedCategory}} | <strong>categoria:</strong> {{selectedCategory}}{{/if}}
            {{#if selectedSubcategory}} | <strong>subcategoria:</strong> {{selectedSubcategory}}{{/if}}
        </p>
    {{/if}}
</div>

{{#if products}}
    <div class="products" id="productsContainer">
    {{#each products}}
    <div class="product-card" data-product-url="/products/{{this._id}}">
        <div class="product-card-media">
            {{#if this.imagePath}}
            <img src="/uploads/{{this.imagePath}}" alt="{{this.name}}" class="product-image">
            {{else}}
            <div class="product-card-placeholder">Sem imagem</div>
            {{/if}}
        </div>

        <div class="product-card-body">
            <h2>{{this.name}}</h2>
            <p class="product-card-price">{{formatCurrency this.price}}</p>
            <a href="/products/{{this._id}}" class="btn product-card-action">Ver Detalhes</a>
        </div>
    </div>
    {{/each}}
</div>
{{else}}
<div class="no-results">
    <h2>Nenhum produto encontrado</h2>
    {{#if hasFilters}}
        <p>Não encontramos produtos com os filtros selecionados.</p>
        <a href="/products" class="btn btn-primary">Ver todos os produtos</a>
    {{else}}
        <p>Nenhum produto cadastrado no sistema</p>
        {{#if user}}
            {{#if (isAdmin user.role)}}
                <a href="/products/create" class="btn btn-primary">Cadastrar Produto</a>
            {{else}}
                <p style="color: #999;">Apenas administradores podem cadastrar produtos.</p>
            {{/if}}
        {{else}}
            <p style="color: #999;"><a href="/auth/login">Faça login</a> como administrador para cadastrar produtos.</p>
        {{/if}}
    {{/if}}
</div>
{{/if}}

<script>
    // Auto-remove success alert after 4 seconds
    const successAlert = document.getElementById('successAlert');
    if (successAlert) {
        setTimeout(() => {
            successAlert.style.transition = 'opacity 0.3s ease';
            successAlert.style.opacity = '0';
            setTimeout(() => {
                successAlert.style.display = 'none';
            }, 300);
        }, 4000);
    }
</script>

<script>
    const categoryMap = {{{categoryMapJson}}};
    const selectedCategory = '{{selectedCategory}}';
    const selectedSubcategory = '{{selectedSubcategory}}';
    const categorySelect = document.getElementById('filter-category');
    const subcategorySelect = document.getElementById('filter-subcategory');

    function fillSubcategories(category, selectedValue) {
        subcategorySelect.innerHTML = '';

        const defaultOption = document.createElement('option');
        defaultOption.value = '';
        defaultOption.textContent = 'Todas as subcategorias';
        subcategorySelect.appendChild(defaultOption);

        if (!category || !categoryMap[category]) {
            return;
        }

        categoryMap[category].forEach((subcategory) => {
            const option = document.createElement('option');
            option.value = subcategory;
            option.textContent = subcategory;
            if (subcategory === selectedValue) {
                option.selected = true;
            }
            subcategorySelect.appendChild(option);
        });
    }

    categorySelect.addEventListener('change', () => {
        fillSubcategories(categorySelect.value, '');
    });

    fillSubcategories(selectedCategory, selectedSubcategory);

    const productsContainer = document.getElementById('productsContainer');
    const viewToggleButtons = document.querySelectorAll('.view-toggle-btn');
    const productsViewStorageKey = 'productsViewMode';

    function applyProductsView(viewMode) {
        if (!productsContainer) return;

        productsContainer.classList.toggle('products-view-list', viewMode === 'list');
        productsContainer.classList.toggle('products-view-grid', viewMode === 'grid');

        viewToggleButtons.forEach((button) => {
            const isCurrent = button.dataset.view === viewMode;
            button.classList.toggle('is-active', isCurrent);
            button.setAttribute('aria-pressed', isCurrent ? 'true' : 'false');
        });
    }

    if (productsContainer && viewToggleButtons.length) {
        const savedViewMode = localStorage.getItem(productsViewStorageKey);
        const initialViewMode = savedViewMode === 'list' ? 'list' : 'grid';

        applyProductsView(initialViewMode);

        viewToggleButtons.forEach((button) => {
            button.addEventListener('click', () => {
                const nextViewMode = button.dataset.view === 'list' ? 'list' : 'grid';
                localStorage.setItem(productsViewStorageKey, nextViewMode);
                applyProductsView(nextViewMode);
            });
        });
    }

    if (productsContainer) {
        productsContainer.addEventListener('click', (event) => {
            const actionButton = event.target.closest('.product-card-action');
            if (actionButton) return;

            const isMobile = window.matchMedia('(max-width: 600px)').matches;
            const isListMode = productsContainer.classList.contains('products-view-list');
            if (!isMobile || !isListMode) return;

            const card = event.target.closest('.product-card[data-product-url]');
            if (!card) return;

            const productUrl = card.dataset.productUrl;
            if (productUrl) {
                window.location.href = productUrl;
            }
        });
    }
</script>