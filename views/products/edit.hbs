<h1 class="page-title">Editar</h1>

<form action="/products/edit/{{product._id}}" method="POST" class="edit-form" enctype="multipart/form-data">
    <div class="form-group">
        <label for="name">Nome:</label>
        <input type="text" id="name" name="name" value="{{product.name}}" required>
    </div>

 <div class="form-group">
     <label for="image">Imagem do Produto:</label>
     <input type="file" id="image" name="image" accept="image/*">
     {{#if product.imagePath}}
          <p style="margin:8px 0 6px;color:#666;font-size:13px;">Imagem atual:</p>
          <img src="/uploads/{{product.imagePath}}" alt="{{product.name}}" style="max-width:140px;max-height:140px;border-radius:8px;border:1px solid #ddd;object-fit:cover;">
     {{/if}}
 </div>
 

    <div class="form-group">
        <label for="description">Descrição:</label>
        <textarea id="description" name="description" rows="8" required>{{product.description}}</textarea>
    </div>

    <div class="form-group">
        <label for="price">Preço:</label>
        <input type="number" id="price" name="price" value="{{product.price}}" step="0.01" required>
    </div>        

    <div class="form-group">
        <label for="available">Disponível:</label>
        <input type="checkbox" id="available" name="available" {{#if product.available}}checked{{/if}}>
    </div>      
    <button type="submit" class="btn">Salvar</button>
</form>                


