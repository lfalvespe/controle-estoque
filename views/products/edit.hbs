<h1 class="page-title">Editar</h1>

{{#if message}}
<div class="alert alert-danger">{{message}}</div>
{{/if}}

<form action="/products/edit/{{product._id}}" method="POST" class="edit-form" enctype="multipart/form-data">
    <div class="form-group">
        <label for="name">Nome:</label>
        <input type="text" id="name" name="name" value="{{product.name}}" required>
    </div>

    <div class="form-group">
        <label for="category">Categoria:</label>
        <select id="category" name="category" required>
            <option value="">Selecione uma categoria</option>
            {{#each categories}}
                <option value="{{this}}" {{#if (eq this ../product.category)}}selected{{/if}}>{{this}}</option>
            {{/each}}
        </select>
    </div>

    <div class="form-group">
        <label for="subcategory">Subcategoria:</label>
        <select id="subcategory" name="subcategory" required>
            <option value="">Selecione uma subcategoria</option>
        </select>
    </div>

 <div class="form-group">
     <label for="image">Imagem do Produto:</label>
     <input type="file" id="image" name="image" accept="image/*">
     {{#if product.imagePath}}
          <p style="margin:8px 0 6px;color:#666;font-size:13px;">Imagem atual:</p>
          <img src="/uploads/{{product.imagePath}}" alt="{{product.name}}" style="max-width:140px;max-height:140px;border-radius:8px;border:1px solid #ddd;object-fit:cover;">
     {{/if}}
 </div>
 

    <div class="form-group">
        <label for="description">Descrição:</label>
        <textarea id="description" name="description" rows="8" required>{{product.description}}</textarea>
    </div>

    <div class="form-group">
        <label for="price">Preço:</label>
        <input type="number" id="price" name="price" value="{{product.price}}" step="0.01" required>
    </div>        

    <div class="form-group">
        <label for="available">Disponível:</label>
        <input type="checkbox" id="available" name="available" {{#if product.available}}checked{{/if}}>
    </div>      
    <button type="submit" class="btn">Salvar</button>
</form>

<script>
    const categoryMap = {{{categoryMapJson}}};
    const selectedCategory = '{{product.category}}';
    const selectedSubcategory = '{{product.subcategory}}';
    const categorySelect = document.getElementById('category');
    const subcategorySelect = document.getElementById('subcategory');

    function fillSubcategories(category, selectedValue) {
        subcategorySelect.innerHTML = '';

        const defaultOption = document.createElement('option');
        defaultOption.value = '';
        defaultOption.textContent = 'Selecione uma subcategoria';
        subcategorySelect.appendChild(defaultOption);

        if (!category || !categoryMap[category]) {
            return;
        }

        categoryMap[category].forEach((subcategory) => {
            const option = document.createElement('option');
            option.value = subcategory;
            option.textContent = subcategory;
            if (subcategory === selectedValue) {
                option.selected = true;
            }
            subcategorySelect.appendChild(option);
        });
    }

    categorySelect.addEventListener('change', () => {
        fillSubcategories(categorySelect.value, '');
    });

    fillSubcategories(selectedCategory, selectedSubcategory);
</script>


