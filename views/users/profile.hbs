<div class="users-container user-profile-container">
    <h1 class="page-title">Meu Perfil</h1>
    <div class="user-profile-card">
        {{#if user.profileImage}}
            <img src="{{resolveImageSrc user.profileImage}}" alt="Foto de perfil" class="user-profile-avatar">
        {{else}}
            <span class="user-profile-avatar-fallback">👤</span>
        {{/if}}
        <span class="user-profile-name">{{user.name}}</span>
        <span class="user-profile-email">{{user.email}}</span>
        <span class="user-profile-role">Tipo: {{#if (eq user.role 'admin')}}Administrador{{else}}Usuário{{/if}}</span>
    </div>
    <div class="user-profile-actions">
        <a href="/users/profile/edit" class="btn btn-primary profile-btn">Alterar Foto e Dados</a>
        <a href="/auth/change-password" class="btn btn-secondary profile-btn">Alterar Senha</a>
    </div>
</div>