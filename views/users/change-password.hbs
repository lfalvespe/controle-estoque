<div class="users-container">
	<h1 class="page-title">Alterar Senha do Usuário</h1>

	{{#if message}}
		<div class="alert alert-danger">{{message}}</div>
	{{/if}}

	<form method="POST" action="/users/{{targetUser._id}}/change-password" class="user-form">
		<input type="hidden" name="_csrf" value="{{csrfToken}}">
		<div class="form-group">
			<label>Usuário:</label>
			<input type="text" value="{{targetUser.name}}" disabled>
		</div>

		<div class="form-group">
			<label>Email:</label>
			<input type="email" value="{{targetUser.email}}" disabled>
		</div>

		<div class="form-group">
			<label for="newPassword">Nova Senha:</label>
			<input type="password" id="newPassword" name="newPassword" minlength="6" required>
		</div>

		<div class="form-group">
			<label for="passwordConfirm">Confirmar Nova Senha:</label>
			<input type="password" id="passwordConfirm" name="passwordConfirm" minlength="6" required>
		</div>

		<div class="form-actions">
			<button type="submit" class="btn btn-primary">Salvar Nova Senha</button>
			<a href="/users/{{targetUser._id}}/edit" class="btn btn-secondary">Voltar</a>
		</div>
	</form>
</div>
